# Copy this file to .env and fill in your keys.

# -------------------------------------------------------------------
# REQUIRED — FlightAware AeroAPI
# Free tier: 500 calls/month (enough to run and demo the app).
# Sign up at: https://flightaware.com/aeroapi/portal
# -------------------------------------------------------------------
AEROAPI_KEY=your_key_here

# -------------------------------------------------------------------
# RECOMMENDED — AviationStack
# Provides per-flight IATA delay reason codes (crew, weather, NAS, etc.)
# These come from airline ACARS data and are far more specific than FAA NAS.
# Free tier: 500 calls/month, HTTP only (paid plan required for HTTPS).
# Sign up at: https://aviationstack.com
# -------------------------------------------------------------------
AVIATIONSTACK_KEY=

# -------------------------------------------------------------------
# RECOMMENDED — AeroDataBox (via RapidAPI)
# Secondary source for delay reasons — used as fallback when AviationStack
# returns no reason code.
# Free tier available at: https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# -------------------------------------------------------------------
AERODATABOX_KEY=

# -------------------------------------------------------------------
# OPTIONAL — OpenSky Network
# Enriches results with live aircraft position (ADS-B).
# Free account at: https://opensky-network.org
# Leave blank to skip position enrichment.
# -------------------------------------------------------------------
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
